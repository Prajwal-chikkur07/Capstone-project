{
  "expo": {
    "name": "SeedlingSpeaks",
    "slug": "seedlingspeaks",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "seedlingspeaks",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F0E8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.seedlingspeaks.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "SeedlingSpeaks needs microphone access to transcribe and translate your speech.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "SeedlingSpeaks needs microphone access to record and translate speech."
        }
      ]
    ]
  }
}
